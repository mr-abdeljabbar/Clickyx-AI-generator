generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  password            String?
  name                String?
  avatar              String?
  role                Role                @default(USER)
  isEmailVerified     Boolean             @default(false)
  isBanned            Boolean             @default(false)
  failedLoginAttempts Int                 @default(0)
  lockedUntil         DateTime?
  googleId            String?             @unique
  credits             Int                 @default(0)
  plan                PlanType            @default(FREE)
  planExpiresAt       DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  creditTransactions  CreditTransaction[]
  generatedImages     GeneratedImage[]
  payments            Payment[]
  refreshTokens       RefreshToken[]
  subscriptions       Subscription[]
  verificationTokens  VerificationToken[]

  @@index([email])
  @@index([googleId])
  @@index([isBanned])
  @@index([plan])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model VerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  paypalSubscriptionId String?            @unique
  plan                 PlanType
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paypalSubscriptionId])
  @@index([status])
  @@index([userId])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  paypalPaymentId String?  @unique
  paypalOrderId   String?
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  plan            PlanType
  status          String
  description     String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paypalPaymentId])
  @@index([status])
  @@index([userId])
}

model CreditTransaction {
  id           String          @id @default(uuid())
  userId       String
  amount       Int
  type         TransactionType
  description  String?
  balanceAfter Int
  metadata     Json?
  createdAt    DateTime        @default(now())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([type])
  @@index([userId])
}

model GeneratedImage {
  id             String   @id @default(uuid())
  userId         String
  prompt         String
  negativePrompt String?
  imageUrl       String
  r2Key          String
  width          Int      @default(1024)
  height         Int      @default(1024)
  creditsUsed    Int      @default(1)
  model          String   @default("@cf/stabilityai/stable-diffusion-xl-base-1.0")
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model AuditLog {
  id        String   @id
  adminId   String
  action    String
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([targetId])
}

model FailedAttempt {
  id        String   @id
  ip        String
  email     String?
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([ip])
}

model Plan {
  id           String   @id
  name         String   @unique
  displayName  String
  price        Decimal? @db.Decimal(10, 2)
  credits      Int
  isMonthly    Boolean  @default(true)
  description  String?
  features     String[]
  paypalPlanId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

enum Role {
  USER
  ADMIN
}

enum PlanType {
  FREE
  PRO
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum TransactionType {
  CREDIT_ADDED
  CREDIT_DEDUCTED
  CREDIT_RESET
  MANUAL_ADJUSTMENT
  REFUND
}
